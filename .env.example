# DroidCortex Configuration

# Redis
REDIS_URL=redis://localhost:6379/0

# Database (SQLite path)
DATABASE_URL=sqlite:///data/db/droidcortex.db

# ADB
ADB_PATH=adb

# Storage
APK_STORAGE_PATH=data/apks
SCREENSHOT_STORAGE_PATH=data/screenshots

# Concurrency
MAX_PARALLEL_DEVICES=3

# AI Providers (configure the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default AI Provider: openai | anthropic | google
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# Server
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173
